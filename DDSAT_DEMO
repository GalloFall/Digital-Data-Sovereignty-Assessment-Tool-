  document.getElementById('dashboard-content').innerHTML=`
  <div class="dash-header">
    <div>
      <h2>Sovereignty Assessment Results</h2>
      <p>${state.org.name} &bull; ${state.org.country} &bull; ${state.org.date}</p>
    </div>
