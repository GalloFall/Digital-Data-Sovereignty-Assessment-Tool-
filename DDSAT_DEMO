// ── OWN ASSESSMENT ──
function startOwnAssessment(){
  const name=document.getElementById('org-name').value.trim();
  const type=document.getElementById('org-type').value;
  const country=document.getElementById('org-country').value.trim();
  if(!name||!type||!country){alert('Please complete the required fields: Organisation Name, Type, and Country.');return;}
  state.isDemoMode=false;
  state.org={name,type,country,assessor:document.getElementById('assessor-name').value.trim(),scope:document.getElementById('assessment-scope').value.trim(),date:new Date().toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'})};
  state.answers={};state.answerIdx={};
  document.getElementById('header-org').textContent=name;
  document.getElementById('header-org').style.display='';
  document.getElementById('demo-badge').style.display='none';
  setDemoBanner(false);
  state.currentDomain='legal';
  showView('assessment');
  renderAssessment();
}

// ── SIDEBAR ──
function renderSidebar(){
  const answered=answeredCount(),total=totalQuestions();
  const pct=Math.round(answered/total*100);
  const score=overallScore();
  const ml=maturityLevel(score);
  let html=`<div class="score-widget">
    <div class="score-widget-label">Live DSI Score</div>
    <div class="score-widget-value">${score}</div>
    <div class="score-widget-level">${ml.label}</div>
    <div class="score-widget-bar"><div class="score-widget-bar-fill" style="width:${score}%"></div></div>
  </div>
  <div class="sidebar-progress-label">Progress</div>
  <div class="sidebar-progress-bar"><div class="sidebar-progress-fill" style="width:${pct}%"></div></div>
  <div class="sidebar-progress-text">${answered} / ${total} questions answered</div>`;
  PILLARS.forEach(p=>{
    const doms=DOMAINS.filter(d=>d.pillar===p.id);
    html+=`<div class="sidebar-pillar-header">${p.label}</div>`;
    doms.forEach(d=>{
      const completed=domainAnswered(d.id);
      const active=d.id===state.currentDomain;
      html+=`<div class="sidebar-domain ${active?'active':''} ${completed&&!active?'completed':''}" onclick="goToDomain('${d.id}')">
        <span>${d.icon} ${d.label}</span>
        <span class="domain-check">${completed?'✓':''}</span>
      </div>`;
    });
  });
  document.getElementById('sidebar').innerHTML=html;
}

function renderAssessment(){
  renderSidebar();
  const domain=DOMAINS.find(d=>d.id===state.currentDomain);
  const pillar=PILLARS.find(p=>p.id===domain.pillar);
  const questions=QUESTIONS[domain.id];
  const domIdx=getDomainIndex(domain.id)+1;
  const prev=getPrevDomain(domain.id);
  const next=getNextDomain(domain.id);
  const allAnswered=domainAnswered(domain.id);

  let qhtml=questions.map((q,i)=>{
    const key=domain.id+'-'+i;
    const optsHtml=q.opts.map(([text,score],oi)=>{
      const isSelIdx=state.answerIdx[key]===oi;
      const scls=['sb-0','sb-1','sb-2','sb-3'][score];
      return `<div class="option-item ${isSelIdx?'selected':''}" onclick="selectOption('${key}',${score},${oi})">
        <div class="option-radio"></div>
        <div class="option-text">${text}</div>
        <span class="option-score-badge ${scls}">${['Critical','Developing','Managed','Optimizing'][score]}</span>
      </div>`;
    }).join('');
    return `<div class="question-card ${state.answers[key]!==undefined?'answered':''}" id="qcard-${key}">
      <div class="question-num">Question ${i+1} of ${questions.length}</div>
      <div class="question-text">${q.text}</div>
      <div class="options-list">${optsHtml}</div>
    </div>`;
  }).join('');

  document.getElementById('assessment-main').innerHTML=`
  <div class="domain-header fade-in">
    <div class="domain-breadcrumb">Pillar ${PILLARS.indexOf(pillar)+1}: <strong>${pillar.label}</strong> › Domain ${domIdx} of ${DOMAINS.length}</div>
    <div class="domain-title">${domain.icon} ${domain.label}</div>
    <div class="domain-desc">${domain.desc}</div>
  </div>
  ${qhtml}
  <div class="assessment-nav no-print">
    <div>${prev?`<button class="btn btn-secondary" onclick="goToDomain('${prev}')">← Previous</button>`:'<span></span>'}</div>
    <div class="nav-info">Domain score: <strong>${domainScore(domain.id)}%</strong> ${allAnswered?'✅':''}</div>
    <div>${next
      ?`<button class="btn btn-primary" onclick="goToDomain('${next}')">Next Domain →</button>`
      :`<button class="btn btn-green" onclick="showDashboard()">Generate Report & KPIs 📊</button>`
    }</div>
  </div>`;
}

function goToDomain(id){state.currentDomain=id;renderAssessment();window.scrollTo(0,0);}
function selectOption(key,score,optIdx){state.answers[key]=score;state.answerIdx[key]=optIdx;renderAssessment();}
function showDashboard(){showView('dashboard');renderDashboard(false);}

// ── DASHBOARD ──
