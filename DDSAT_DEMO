  <div class="dsi-hero slide-up">
    <div class="dsi-score-ring">
      <canvas id="dsiRing" width="120" height="120"></canvas>
      <div class="dsi-score-text">
        <div class="dsi-score-num">${score}</div>
        <div class="dsi-score-pct">/ 100</div>
      </div>
    </div>
    <div class="dsi-meta">
      <h3>Digital Sovereignty Index: ${score}</h3>
      <p>Based on ${answeredCount()} responses across 14 domains and 5 pillars. This index represents the organisation's overall digital sovereignty posture.</p>
      <span class="maturity-badge ${ml.cls}">${ml.label} Maturity Level</span>
      ${demoNote}
    </div>
  </div>

  <div class="kpi-grid" id="kpi-grid"></div>

  <div class="charts-row">
    <div class="chart-card">
      <div class="chart-title">Pillar Radar — Sovereignty Posture</div>
      <div class="chart-sub">Score across all five assessment pillars (0–100)</div>
      <div class="chart-wrap"><canvas id="radarChart"></canvas></div>
    </div>
    <div class="chart-card">
      <div class="chart-title">Pillar Scores — Comparative View</div>
      <div class="chart-sub">Weighted contribution to overall Digital Sovereignty Index</div>
      <div class="chart-wrap"><canvas id="pillarBar"></canvas></div>
