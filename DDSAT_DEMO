function renderKPICards(){
  const kpis=generateKPIs();
  const cardHtml=kpi=>`<div class="kpi-card kpi-${kpi.color}">
    <div class="kpi-label">${kpi.label}</div>
    <div class="kpi-value kv-${kpi.color}">${kpi.value}</div>
    <div class="kpi-sub">${kpi.sub}</div>
    <div class="kpi-mini-bar"><div class="kpi-mini-bar-fill fill-${kpi.color}" style="width:${kpi.pct}%"></div></div>
  </div>`;
  const g1=document.getElementById('kpi-grid');
  const g2=document.getElementById('kpi-grid-2');
  if(g1)g1.innerHTML=kpis.slice(0,8).map(cardHtml).join('');
  if(g2)g2.innerHTML=kpis.slice(8).map(cardHtml).join('');
}

function generateKPIs(){
  const s=n=>domainScore(n);
  const ps=pid=>pillarScore(pid);
  const c=sc=>{if(sc>=80)return'green';if(sc>=60)return'blue';if(sc>=40)return'amber';return'red';};
  const kpi=(label,raw,unit,sub)=>({label,value:`${raw}${unit||'%'}`,pct:raw,color:c(raw),sub});
  return [
    kpi('Digital Sovereignty Index (DSI)',overallScore(),'','Overall sovereignty posture score'),
    kpi('Legal & Regulatory Alignment',ps('P1'),'','Pillar 1 — legal framework maturity'),
    kpi('Data Residency Compliance',Math.round((s('residency')+s('cloud'))/2),'','Data localisation and cloud sovereignty'),
    kpi('Infrastructure Control Score',Math.round((s('infra')+s('cloud'))/2),'','National infrastructure ownership & control'),
    kpi('Encryption Sovereignty',s('encrypt'),'','Key management and cryptographic standards'),
    kpi('AI Governance Index',s('aiGov'),'','AI inventory, oversight, and data provenance'),
    kpi('Vendor Dependency Risk',100-Math.round((s('vendor')+s('vendoraudit'))/2),'%','Inverted: lower = more sovereign (higher = risk)'),
    kpi('Cross-Border Governance',s('crossborder'),'','International data flow controls'),
    kpi('Critical Infra Resilience',s('critinfra'),'','CNI protection programme maturity'),
    kpi('IAM Maturity',s('iam'),'','Identity and access management strength'),
    kpi('Operational Resilience',s('ops'),'','Crisis operations and vendor independence'),
    kpi('Executive Oversight Index',s('institutional'),'','Board-level accountability and strategy'),
  ];
}

function generateRecommendations(){
  const actions={
    legal:'Establish or strengthen a national data protection law with independent DPA enforcement powers.',
    dataprotect:'Appoint a qualified DPO, implement systematic DPIAs, and test breach notification procedures.',
    residency:'Complete a data inventory, enforce residency clauses in all vendor contracts, and verify compliance.',
    infra:'Increase national ownership of critical IT infrastructure; establish vendor-independent operating procedures.',
    cloud:'Adopt a sovereign cloud strategy, review all cloud contracts for jurisdiction and exit provisions.',
    encrypt:'Implement nationally-controlled HSMs, enforce cryptographic standards, and establish key lifecycle governance.',
    critinfra:'Formalise a CNI register, establish a 24/7 CSIRT with CNI mandate, and conduct annual exercises.',
    vendor:'Implement a prohibited vendor list, mandate sovereignty clauses in all contracts, and verify supply chains.',
    crossborder:'Introduce a cross-border transfer policy, complete transfer impact assessments, and maintain a transfer register.',
    vendoraudit:'Deploy immutable vendor access logging, enforce JIT privileged access, and mandate supervised support sessions.',
    iam:'Deploy enterprise IAM and PAM, enforce MFA universally, and implement zero-trust architecture.',
    aiGov:'Create a complete AI system inventory, implement an AI governance framework, and control training data provenance.',
    ops:'Develop vendor-independent operating procedures, test sovereign BCP scenarios, and invest in national cyber skills.',
    institutional:'Appoint a board-level sovereignty executive, establish a ring-fenced budget, and define measurable sovereignty KPIs.'
  };
  return DOMAINS.map(d=>{
    const sc=domainScore(d.id);
    return {domain:d.label,title:`Improve ${d.label}`,desc:actions[d.id],priority:sc<40?'high':sc<65?'medium':'low',score:sc};
  }).sort((a,b)=>a.score-b.score);
}

// ── CHARTS ──
function destroyChart(id){if(state.charts[id]){state.charts[id].destroy();delete state.charts[id];}}

function renderRingChart(score){
  destroyChart('dsi');
  const ctx=document.getElementById('dsiRing').getContext('2d');
  state.charts['dsi']=new Chart(ctx,{type:'doughnut',data:{datasets:[{data:[score,100-score],backgroundColor:[scoreColorHex(score),'rgba(255,255,255,0.1)'],borderWidth:0}]},options:{cutout:'72%',plugins:{legend:{display:false},tooltip:{enabled:false}},animation:{duration:1000}}});
}
function renderRadarChart(scores){
  destroyChart('radar');
  const ctx=document.getElementById('radarChart').getContext('2d');
  state.charts['radar']=new Chart(ctx,{type:'radar',data:{labels:PILLARS.map(p=>p.label.split(' ').slice(0,3).join(' ')),datasets:[{label:'Score',data:scores,backgroundColor:'rgba(37,99,235,0.15)',borderColor:'#2563eb',borderWidth:2,pointBackgroundColor:'#2563eb',pointRadius:4}]},options:{scales:{r:{min:0,max:100,ticks:{stepSize:20,font:{size:10}},grid:{color:'rgba(0,0,0,0.07)'},pointLabels:{font:{size:11,weight:'700'},color:'#334155'}}},plugins:{legend:{display:false}},animation:{duration:800}}});
}
function renderPillarBar(scores){
  destroyChart('pillarBar');
  const ctx=document.getElementById('pillarBar').getContext('2d');
  state.charts['pillarBar']=new Chart(ctx,{type:'bar',data:{labels:PILLARS.map((p,i)=>`P${i+1}`),datasets:[{label:'Pillar Score',data:scores,backgroundColor:scores.map(s=>scoreColorHex(s)+'cc'),borderColor:scores.map(scoreColorHex),borderWidth:2,borderRadius:8}]},options:{scales:{y:{min:0,max:100,ticks:{stepSize:20},grid:{color:'rgba(0,0,0,0.05)'}},x:{grid:{display:false}}},plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`Score: ${c.raw}%`}}},animation:{duration:800}}});
}
function renderDomainBar(){
  destroyChart('domainBar');
  const ctx=document.getElementById('domainBar').getContext('2d');
  const scores=DOMAINS.map(d=>domainScore(d.id));
  state.charts['domainBar']=new Chart(ctx,{type:'bar',data:{labels:DOMAINS.map(d=>d.label),datasets:[{label:'Domain Score',data:scores,backgroundColor:scores.map(s=>scoreColorHex(s)+'cc'),borderColor:scores.map(scoreColorHex),borderWidth:1.5,borderRadius:6}]},options:{indexAxis:'y',scales:{x:{min:0,max:100,ticks:{stepSize:20},grid:{color:'rgba(0,0,0,0.05)'}},y:{grid:{display:false},ticks:{font:{size:11}}}},plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`${c.raw}%`}}},animation:{duration:600}}});
}
</script>
</body>
</html>
