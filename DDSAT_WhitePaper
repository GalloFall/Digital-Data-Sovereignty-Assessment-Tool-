
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="DDSAT White Paper — A Methodology for Strengthening Government and Critical Infrastructure Digital Sovereignty">
<title>DDSAT White Paper — Digital & Data Sovereignty Assessment Tool</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400;1,600&display=swap" rel="stylesheet">
<style>
/* ─── RESET & BASE ─────────────────────────────────────────── */
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0f172a;--navy-mid:#1e3a5f;--navy-light:#1e293b;
  --gold:#f59e0b;--gold-light:#fef3c7;--gold-dark:#d97706;
  --blue:#2563eb;--green:#059669;--purple:#7c3aed;--rose:#db2777;--amber:#d97706;
  --gray-50:#f8fafc;--gray-100:#f1f5f9;--gray-200:#e2e8f0;
  --gray-300:#cbd5e1;--gray-400:#94a3b8;--gray-500:#64748b;
  --gray-600:#475569;--gray-700:#334155;--gray-800:#1e293b;
  --body-font:'Inter',sans-serif;
  --heading-font:'Playfair Display',Georgia,serif;
}
html{font-size:16px;scroll-behavior:smooth}
body{font-family:var(--body-font);color:var(--gray-800);background:#fff;line-height:1.7}
a{color:var(--blue);text-decoration:none}
a:hover{text-decoration:underline}

/* ─── PRINT ────────────────────────────────────────────────── */
@media print{
  .no-print{display:none!important}
  .page-break{page-break-before:always}
  body{font-size:11pt}
  .cover{min-height:100vh}
  section{page-break-inside:avoid}
  .doc-footer{position:fixed;bottom:0;left:0;right:0}
}
@page{margin:20mm 18mm}

/* ─── NAV BAR (screen only) ────────────────────────────────── */
.topnav{background:var(--navy);padding:10px 32px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;no-print}
.topnav-brand{display:flex;align-items:center;gap:10px;color:#fff;font-size:14px;font-weight:700}
.topnav-logo{width:32px;height:32px;background:linear-gradient(135deg,var(--blue),var(--gold));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:900;color:#fff}
.topnav-links{display:flex;gap:18px}
.topnav-links a{color:rgba(255,255,255,.7);font-size:12px;font-weight:600;text-decoration:none;transition:color .15s}
.topnav-links a:hover{color:#fff}
.topnav-btn{background:var(--gold);color:var(--navy);padding:6px 16px;border-radius:6px;font-size:12px;font-weight:800;text-decoration:none;transition:all .15s}
.topnav-btn:hover{background:var(--gold-dark);color:#fff;text-decoration:none}

/* ─── WRAPPER ───────────────────────────────────────────────── */
.wp-wrap{max-width:900px;margin:0 auto;padding:0 32px 80px}

/* ─── COVER PAGE ────────────────────────────────────────────── */
.cover{background:linear-gradient(160deg,var(--navy) 0%,var(--navy-mid) 60%,#1e3a8a 100%);color:#fff;min-height:92vh;display:flex;flex-direction:column;justify-content:center;padding:80px 60px;position:relative;overflow:hidden}
.cover::before{content:'';position:absolute;top:-80px;right:-80px;width:400px;height:400px;border-radius:50%;border:2px solid rgba(245,158,11,.15)}
.cover::after{content:'';position:absolute;top:-40px;right:-40px;width:280px;height:280px;border-radius:50%;border:2px solid rgba(245,158,11,.1)}
.cover-decor{position:absolute;bottom:-60px;left:-60px;width:300px;height:300px;border-radius:50%;border:2px solid rgba(255,255,255,.05)}

/* CSS Shield Icon */
.shield-wrap{margin-bottom:40px;display:flex;align-items:center;gap:20px}
.shield{width:80px;height:88px;position:relative}
.shield-body{width:80px;height:70px;background:linear-gradient(135deg,var(--gold),var(--gold-dark));border-radius:12px 12px 0 0;display:flex;align-items:center;justify-content:center;font-size:28px}
.shield-tip{width:0;height:0;border-left:40px solid transparent;border-right:40px solid transparent;border-top:22px solid var(--gold-dark)}
.shield-inner{font-size:28px;filter:drop-shadow(0 2px 4px rgba(0,0,0,.3))}
.cover-eyebrow{font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:16px;opacity:.9}
.cover-title{font-family:var(--heading-font);font-size:38px;font-weight:800;line-height:1.2;letter-spacing:-.5px;margin-bottom:12px;max-width:680px}
.cover-subtitle{font-size:14px;font-weight:400;color:rgba(255,255,255,.75);margin-bottom:32px;letter-spacing:.3px}
.cover-abstract{font-size:13.5px;line-height:1.75;color:rgba(255,255,255,.8);max-width:620px;margin-bottom:40px;border-left:3px solid var(--gold);padding-left:20px}
.cover-meta{display:flex;gap:0;border-top:1px solid rgba(255,255,255,.15);padding-top:28px;flex-wrap:wrap}
.cover-meta-item{flex:1;min-width:140px;padding:0 24px;border-right:1px solid rgba(255,255,255,.12)}
.cover-meta-item:first-child{padding-left:0}
.cover-meta-item:last-child{border-right:none}
.cover-meta-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,.45);margin-bottom:6px}
.cover-meta-value{font-size:13px;font-weight:600;color:#fff}

/* ─── TABLE OF CONTENTS ─────────────────────────────────────── */
.toc-section{background:var(--gray-50);border:1px solid var(--gray-200);border-radius:14px;padding:36px 40px;margin:48px 0}
.toc-title{font-family:var(--heading-font);font-size:18px;font-weight:700;color:var(--navy);margin-bottom:24px;padding-bottom:12px;border-bottom:2px solid var(--gold)}
.toc-grid{display:grid;grid-template-columns:1fr 1fr;gap:0}
.toc-item{display:flex;align-items:baseline;gap:8px;padding:7px 0;border-bottom:1px dashed var(--gray-200)}
.toc-num{font-size:12px;font-weight:800;color:var(--gold);min-width:24px}
.toc-text{font-size:13px;color:var(--gray-700);font-weight:500;flex:1}
.toc-text a{color:var(--gray-700);text-decoration:none}
.toc-text a:hover{color:var(--blue)}
.toc-dots{flex:1;border-bottom:1px dotted var(--gray-300);margin:0 6px;position:relative;top:-3px}
.toc-page{font-size:11px;color:var(--gray-400);font-weight:600}

/* ─── SECTIONS ──────────────────────────────────────────────── */
.wp-section{margin-bottom:56px}
.section-header{margin-bottom:28px}
.section-eyebrow{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:2px;color:var(--gold);margin-bottom:8px}
.section-title{font-family:var(--heading-font);font-size:28px;font-weight:700;color:var(--navy);line-height:1.2;letter-spacing:-.3px;padding-left:18px;border-left:4px solid var(--gold)}
.subsection{margin-top:28px;margin-bottom:20px}
.subsection-title{font-family:var(--heading-font);font-size:18px;font-weight:600;color:var(--navy-mid);margin-bottom:10px;display:flex;align-items:center;gap:10px}
.subsection-title::before{content:'';display:inline-block;width:4px;height:18px;background:var(--gold);border-radius:2px;flex-shrink:0}
p{margin-bottom:14px;font-size:14.5px;color:var(--gray-700);line-height:1.8}
p:last-child{margin-bottom:0}

/* ─── CALLOUT BOX ───────────────────────────────────────────── */
.callout{border-radius:12px;padding:24px 28px;margin:24px 0}
.callout-gold{background:linear-gradient(135deg,#fffbeb,#fef3c7);border:1px solid #fcd34d}
.callout-blue{background:linear-gradient(135deg,#eff6ff,#dbeafe);border:1px solid #93c5fd}
.callout-navy{background:var(--navy);color:#fff;border:none}
.callout-label{font-size:10px;font-weight:900;text-transform:uppercase;letter-spacing:1.5px;color:var(--gold-dark);margin-bottom:10px}
.callout-navy .callout-label{color:var(--gold)}
.callout-title{font-family:var(--heading-font);font-size:15px;font-weight:700;color:var(--navy);margin-bottom:12px}
.callout-navy .callout-title{color:#fff}
.risk-drivers{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:14px}
.risk-driver{background:rgba(255,255,255,.7);border-radius:8px;padding:14px;border-left:3px solid var(--gold-dark)}
.risk-driver-num{font-size:20px;font-weight:900;color:var(--gold-dark);line-height:1}
.risk-driver-title{font-size:12px;font-weight:800;color:var(--navy);margin-top:4px}
.risk-driver-desc{font-size:11.5px;color:var(--gray-600);margin-top:4px;line-height:1.5}

/* ─── PRINCIPLES GRID ───────────────────────────────────────── */
.principles-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin:24px 0}
.principle-card{background:#fff;border:1.5px solid var(--gray-200);border-radius:12px;padding:18px 14px;text-align:center;transition:border-color .2s}
.principle-card:hover{border-color:var(--gold)}
.principle-icon{font-size:24px;margin-bottom:10px}
.principle-title{font-size:11px;font-weight:800;color:var(--navy);margin-bottom:6px;text-transform:uppercase;letter-spacing:.3px}
.principle-desc{font-size:11px;color:var(--gray-500);line-height:1.5}

/* ─── PILLAR TABLE ───────────────────────────────────────────── */
.pillar-table{width:100%;border-collapse:collapse;margin:24px 0;border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.07)}
.pillar-table th{background:var(--navy);color:#fff;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.8px;padding:12px 16px;text-align:left}
.pillar-table td{padding:14px 16px;font-size:13.5px;border-bottom:1px solid var(--gray-100);vertical-align:middle}
.pillar-table tr:last-child td{border-bottom:none}
.pillar-table tr:hover td{background:var(--gray-50)}
.pillar-table tr:nth-child(odd) td{background:#fafafa}
.pillar-color{width:14px;height:14px;border-radius:4px;display:inline-block;vertical-align:middle;margin-right:8px}
.pillar-name-cell{font-weight:700;color:var(--navy)}
.weight-badge{display:inline-block;background:var(--gold-light);color:var(--gold-dark);font-size:11px;font-weight:800;padding:2px 10px;border-radius:20px;border:1px solid #fcd34d}

/* ─── DOMAIN CARDS ───────────────────────────────────────────── */
.domains-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:24px 0}
.domain-card{background:#fff;border:1.5px solid var(--gray-200);border-radius:12px;padding:16px 18px;display:flex;gap:12px;align-items:flex-start}
.domain-card:hover{border-color:var(--gray-300);box-shadow:0 2px 8px rgba(0,0,0,.06)}
.domain-icon{font-size:22px;flex-shrink:0;margin-top:1px}
.domain-info{}
.domain-name{font-size:13px;font-weight:700;color:var(--navy);margin-bottom:3px}
.domain-desc-card{font-size:11.5px;color:var(--gray-500);line-height:1.5}
.domain-pillar-tag{font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.5px;display:inline-block;padding:1px 7px;border-radius:20px;margin-bottom:5px}
.pt1{background:#ede9fe;color:#6d28d9}
.pt2{background:#dbeafe;color:#1d4ed8}
.pt3{background:#fce7f3;color:#9d174d}
.pt4{background:#d1fae5;color:#065f46}
.pt5{background:#fef9c3;color:#713f12}

/* ─── FORMULA BOX ────────────────────────────────────────────── */
.formula-box{background:var(--gray-50);border:2px solid var(--gray-200);border-radius:10px;padding:20px 24px;margin:20px 0;font-family:'Courier New',Courier,monospace}
.formula-label{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:var(--gray-400);margin-bottom:10px;font-family:var(--body-font)}
.formula-line{font-size:13px;color:var(--navy);margin-bottom:6px;line-height:1.6}
.formula-line strong{color:var(--blue)}
.formula-note{font-size:11px;color:var(--gray-500);margin-top:10px;font-family:var(--body-font);line-height:1.5}

/* ─── MATURITY BAR ───────────────────────────────────────────── */
.maturity-container{margin:24px 0}
.maturity-bar{display:flex;height:36px;border-radius:10px;overflow:hidden;box-shadow:0 2px 6px rgba(0,0,0,.1)}
.mat-seg{display:flex;align-items:center;justify-content:center;flex:1;font-size:10px;font-weight:800;color:#fff;text-transform:uppercase;letter-spacing:.5px;position:relative}
.mat-initial{background:#ef4444}
.mat-developing{background:#f97316}
.mat-defined{background:#f59e0b}
.mat-managed{background:#2563eb}
.mat-optimizing{background:#10b981}
.maturity-labels{display:flex;margin-top:8px}
.mat-label{flex:1;text-align:center;font-size:10px;color:var(--gray-500);font-weight:600}
.maturity-levels{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-top:20px}
.mat-level-card{border-radius:10px;padding:14px;border:1px solid var(--gray-200)}
.mat-level-card.ml-initial{border-left:4px solid #ef4444;background:#fff5f5}
.mat-level-card.ml-developing{border-left:4px solid #f97316;background:#fff7ed}
.mat-level-card.ml-defined{border-left:4px solid #f59e0b;background:#fffbeb}
.mat-level-card.ml-managed{border-left:4px solid #2563eb;background:#eff6ff}
.mat-level-card.ml-optimizing{border-left:4px solid #10b981;background:#f0fdf4}
.mat-level-name{font-size:11px;font-weight:800;color:var(--navy);margin-bottom:4px}
.mat-level-range{font-size:10px;font-weight:700;margin-bottom:6px}
.mat-level-range.r-initial{color:#ef4444}.mat-level-range.r-developing{color:#f97316}.mat-level-range.r-defined{color:#f59e0b}.mat-level-range.r-managed{color:#2563eb}.mat-level-range.r-optimizing{color:#10b981}
.mat-level-desc{font-size:10.5px;color:var(--gray-600);line-height:1.5}

/* ─── KPI TABLE ──────────────────────────────────────────────── */
.kpi-table{width:100%;border-collapse:collapse;margin:20px 0;font-size:12.5px}
.kpi-table th{background:var(--navy);color:#fff;padding:11px 14px;text-align:left;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.7px}
.kpi-table td{padding:12px 14px;border-bottom:1px solid var(--gray-100);vertical-align:top;line-height:1.5}
.kpi-table tr:hover td{background:var(--gray-50)}
.kpi-name{font-weight:700;color:var(--navy)}
.kpi-formula{font-family:monospace;font-size:11px;color:var(--gray-600);display:block;margin-top:3px}
.threshold-g{display:inline-block;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:800;background:#dcfce7;color:#15803d}
.threshold-a{display:inline-block;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:800;background:#fef9c3;color:#854d0e}
.threshold-r{display:inline-block;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:800;background:#fee2e2;color:#991b1b}

/* ─── OUTCOME CARDS ──────────────────────────────────────────── */
.outcome-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:28px 0}
.outcome-card{border-radius:14px;padding:24px;position:relative;overflow:hidden}
.outcome-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px}
.oc-citizen{background:linear-gradient(135deg,#eff6ff,#dbeafe);border:1px solid #bfdbfe}
.oc-citizen::before{background:var(--blue)}
.oc-infra{background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:1px solid #bbf7d0}
.oc-infra::before{background:var(--green)}
.oc-continuity{background:linear-gradient(135deg,#fffbeb,#fef3c7);border:1px solid #fde68a}
.oc-continuity::before{background:var(--gold)}
.oc-icon{font-size:28px;margin-bottom:10px}
.oc-title{font-family:var(--heading-font);font-size:15px;font-weight:700;color:var(--navy);margin-bottom:8px}
.oc-desc{font-size:12px;color:var(--gray-600);line-height:1.6}

/* ─── ROADMAP ────────────────────────────────────────────────── */
.roadmap{position:relative;margin:28px 0}
.roadmap-line{position:absolute;left:26px;top:30px;bottom:30px;width:2px;background:linear-gradient(180deg,var(--blue),var(--green));border-radius:2px}
.roadmap-phase{display:flex;gap:20px;align-items:flex-start;margin-bottom:24px;position:relative}
.phase-dot{width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:900;color:#fff;flex-shrink:0;position:relative;z-index:1;box-shadow:0 3px 10px rgba(0,0,0,.2)}
.pd-1{background:linear-gradient(135deg,#6366f1,#4f46e5)}
.pd-2{background:linear-gradient(135deg,var(--blue),#1d4ed8)}
.pd-3{background:linear-gradient(135deg,#0ea5e9,#0284c7)}
.pd-4{background:linear-gradient(135deg,var(--green),#047857)}
.phase-content{flex:1;background:#fff;border:1.5px solid var(--gray-200);border-radius:12px;padding:18px 20px}
.phase-timing{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:var(--gray-400);margin-bottom:5px}
.phase-title{font-size:14px;font-weight:800;color:var(--navy);margin-bottom:8px}
.phase-items{list-style:none;padding:0}
.phase-items li{font-size:12.5px;color:var(--gray-600);padding:3px 0;display:flex;align-items:baseline;gap:7px;line-height:1.5}
.phase-items li::before{content:'›';color:var(--gold-dark);font-weight:900;flex-shrink:0}

/* ─── GLOSSARY ───────────────────────────────────────────────── */
.glossary-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:20px}
.glossary-item{background:var(--gray-50);border:1px solid var(--gray-200);border-radius:10px;padding:14px 16px}
.glossary-term{font-size:12px;font-weight:800;color:var(--navy);margin-bottom:5px}
.glossary-def{font-size:11.5px;color:var(--gray-600);line-height:1.6}

/* ─── DOC FOOTER ─────────────────────────────────────────────── */
.doc-footer{background:var(--gray-50);border-top:1px solid var(--gray-200);padding:14px 0;margin-top:60px;text-align:center;font-size:11px;color:var(--gray-400)}
.doc-footer strong{color:var(--gray-600)}

/* ─── DIVIDER ────────────────────────────────────────────────── */
.section-divider{border:none;border-top:1px solid var(--gray-200);margin:48px 0}

/* ─── RESPONSIVE ─────────────────────────────────────────────── */
@media(max-width:768px){
  .cover{padding:48px 28px;min-height:auto}
  .cover-title{font-size:26px}
  .toc-grid{grid-template-columns:1fr}
  .principles-grid{grid-template-columns:repeat(2,1fr)}
  .domains-grid{grid-template-columns:1fr}
  .outcome-cards{grid-template-columns:1fr}
  .maturity-levels{grid-template-columns:1fr 1fr}
  .risk-drivers{grid-template-columns:1fr}
  .glossary-grid{grid-template-columns:1fr}
  .cover-meta{flex-direction:column;gap:16px}
  .cover-meta-item{border-right:none;border-bottom:1px solid rgba(255,255,255,.1);padding:0 0 16px 0}
  .wp-wrap{padding:0 16px 60px}
}
</style>
</head>
