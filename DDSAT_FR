const state = {
  org: {}, answers: {}, answerIdx: {}, currentDomain: 'legal', view: 'welcome', charts: {}
};

function getDomainIndex(id){ return DOMAINS.findIndex(d=>d.id===id); }
function getNextDomain(id){ const i=getDomainIndex(id); return i<DOMAINS.length-1?DOMAINS[i+1].id:null; }
function getPrevDomain(id){ const i=getDomainIndex(id); return i>0?DOMAINS[i-1].id:null; }
function domainAnswered(id){ return QUESTIONS[id].every((_,i)=>state.answers[id+'-'+i]!==undefined); }
function domainScore(id){
  const qs=QUESTIONS[id]; let total=0,max=0;
  qs.forEach((q,i)=>{max+=3;if(state.answers[id+'-'+i]!==undefined)total+=state.answers[id+'-'+i];});
  return max>0?Math.round(total/max*100):0;
}
function pillarScore(pid){
  const doms=DOMAINS.filter(d=>d.pillar===pid);
  return doms.length?Math.round(doms.map(d=>domainScore(d.id)).reduce((a,b)=>a+b,0)/doms.length):0;
}
function overallScore(){
  const w={P1:0.20,P2:0.25,P3:0.20,P4:0.15,P5:0.20};
  return Math.round(PILLARS.reduce((acc,p)=>acc+pillarScore(p.id)*w[p.id],0));
}
function maturityLevel(score){
  if(score>=80)return{label:'Optimisant',cls:'mb-optimisant',color:'#10b981'};
  if(score>=60)return{label:'Géré',cls:'mb-géré',color:'#2563eb'};
  if(score>=40)return{label:'Défini',cls:'mb-défini',color:'#d97706'};
  if(score>=20)return{label:'En développement',cls:'mb-développement',color:'#ef4444'};
  return{label:'Initial / Ad hoc',cls:'mb-initial',color:'#ef4444'};
}
function scoreColor(s){if(s>=80)return'green';if(s>=60)return'blue';if(s>=40)return'amber';return'red';}
function scorePillClass(s){if(s>=80)return'sp-excellent';if(s>=60)return'sp-good';if(s>=40)return'sp-fair';if(s>=20)return'sp-poor';return'sp-critical';}
function scoreColorHex(s){if(s>=80)return'#10b981';if(s>=60)return'#2563eb';if(s>=40)return'#f59e0b';return'#ef4444';}
function answeredCount(){return Object.keys(state.answers).length;}
function totalQuestions(){return Object.values(QUESTIONS).reduce((a,q)=>a+q.length,0);}

function showView(v){
  document.querySelectorAll('.view').forEach(el=>el.classList.remove('active'));
  document.getElementById('view-'+v).classList.add('active');
  state.view=v;
}

function startAssessment(){
  const name=document.getElementById('org-name').value.trim();
  const type=document.getElementById('org-type').value;
  const country=document.getElementById('org-country').value.trim();
  if(!name||!type||!country){alert('Veuillez renseigner les champs obligatoires : Nom, Type et Pays.');return;}
  state.org={name,type,country,assessor:document.getElementById('assessor-name').value.trim(),scope:document.getElementById('assessment-scope').value.trim(),date:new Date().toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'})};
  document.getElementById('header-org').textContent=name;
  document.getElementById('header-org').style.display='';
  state.currentDomain='legal';
  showView('assessment');
  renderAssessment();
}

function renderSidebar(){
  const answered=answeredCount(),total=totalQuestions();
  const pct=Math.round(answered/total*100);
  const score=overallScore();
  const ml=maturityLevel(score);
  let html=`<div class="score-widget">
    <div class="score-widget-label">Score ISN en direct</div>
    <div class="score-widget-value">${score}</div>
    <div class="score-widget-level">${ml.label}</div>
    <div class="score-widget-bar"><div class="score-widget-bar-fill" style="width:${score}%"></div></div>
  </div>
  <div class="sidebar-progress-label">Progression</div>
  <div class="sidebar-progress-bar"><div class="sidebar-progress-fill" style="width:${pct}%"></div></div>
  <div class="sidebar-progress-text">${answered} / ${total} questions répondues</div>`;
  PILLARS.forEach(p=>{
    const doms=DOMAINS.filter(d=>d.pillar===p.id);
    html+=`<div class="sidebar-pillar-header">${p.label}</div>`;
    doms.forEach(d=>{
      const completed=domainAnswered(d.id);
      const active=d.id===state.currentDomain;
      html+=`<div class="sidebar-domain ${active?'active':''} ${completed&&!active?'completed':''}" onclick="goToDomain('${d.id}')">
        <span>${d.icon} ${d.label}</span>
        <span class="domain-check">${completed?'✓':''}</span>
      </div>`;
    });
  });
  document.getElementById('sidebar').innerHTML=html;
}

function renderAssessment(){
  renderSidebar();
  const domain=DOMAINS.find(d=>d.id===state.currentDomain);
  const pillar=PILLARS.find(p=>p.id===domain.pillar);
  const questions=QUESTIONS[domain.id];
  const domIdx=getDomainIndex(domain.id)+1;
  const prev=getPrevDomain(domain.id);
  const next=getNextDomain(domain.id);
  const allAnswered=domainAnswered(domain.id);
  const NIVEAUX=['Critique','En développement','Géré','Optimisant'];

  let qhtml=questions.map((q,i)=>{
    const key=domain.id+'-'+i;
    const sel=state.answers[key];
    const optsHtml=q.opts.map(([text,score],oi)=>{
      const isSelIdx=state.answerIdx[key]===oi;
      const scls=['sb-0','sb-1','sb-2','sb-3'][score];
      return `<div class="option-item ${isSelIdx?'selected':''}" onclick="selectOption('${key}',${score},${oi})">
        <div class="option-radio"></div>
        <div class="option-text">${text}</div>
        <span class="option-score-badge ${scls}">${NIVEAUX[score]}</span>
      </div>`;
    }).join('');
    return `<div class="question-card ${sel!==undefined?'answered':''}" id="qcard-${key}">
      <div class="question-num">Question ${i+1} sur ${questions.length}</div>
      <div class="question-text">${q.text}</div>
      <div class="options-list">${optsHtml}</div>
    </div>`;
  }).join('');

  const dScore=domainScore(domain.id);
  document.getElementById('assessment-main').innerHTML=`
  <div class="domain-header fade-in">
    <div class="domain-breadcrumb">Pilier ${PILLARS.indexOf(pillar)+1} : <strong>${pillar.label}</strong> › Domaine ${domIdx} sur ${DOMAINS.length}</div>
    <div class="domain-title">${domain.icon} ${domain.label}</div>
    <div class="domain-desc">${domain.desc}</div>
  </div>
  ${qhtml}
  <div class="assessment-nav no-print">
    <div>${prev?`<button class="btn btn-secondary" onclick="goToDomain('${prev}')">← Précédent</button>`:'<span></span>'}</div>
    <div class="nav-info">Score du domaine : <strong>${dScore}%</strong> ${allAnswered?'✅':''}</div>
    <div>${next
      ?`<button class="btn btn-primary" onclick="goToDomain('${next}')">Domaine suivant →</button>`
      :`<button class="btn btn-green" onclick="showDashboard()">Générer le rapport & les KPIs 📊</button>`
    }</div>
  </div>`;
}

function goToDomain(id){state.currentDomain=id;renderAssessment();window.scrollTo(0,0);}

function selectOption(key,score,optIdx){
  state.answers[key]=score;
  state.answerIdx[key]=optIdx;
  renderAssessment();
}

function showDashboard(){showView('dashboard');renderDashboard();}

