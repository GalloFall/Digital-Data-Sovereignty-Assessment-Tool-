
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OESD — Outil d'Évaluation de la Souveraineté Numérique</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root{--navy:#0f172a;--navy-mid:#1e3a5f;--blue:#2563eb;--sky:#0ea5e9;--green:#10b981;--amber:#f59e0b;--red:#ef4444;--gray-50:#f8fafc;--gray-100:#f1f5f9;--gray-200:#e2e8f0;--gray-300:#cbd5e1;--gray-400:#94a3b8;--gray-500:#64748b;--gray-600:#475569;--gray-700:#334155;--gray-800:#1e293b;--gray-900:#0f172a}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--gray-50);color:var(--gray-800);min-height:100vh}
.header{background:linear-gradient(135deg,var(--navy) 0%,var(--navy-mid) 100%);padding:14px 28px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 12px rgba(0,0,0,.35);position:sticky;top:0;z-index:200}
.header-brand{display:flex;align-items:center;gap:12px}
.header-logo{width:42px;height:42px;background:linear-gradient(135deg,var(--blue),var(--sky));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:900;color:#fff;letter-spacing:-1px}
.header-title h1{font-size:17px;font-weight:800;color:#fff;letter-spacing:-.3px}
.header-title p{font-size:11px;color:rgba(255,255,255,.55);margin-top:2px}
.header-right{display:flex;align-items:center;gap:10px}
.header-badge{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.85);padding:5px 13px;border-radius:20px;font-size:11px;font-weight:600}
.view{display:none}.view.active{display:block}
.welcome-wrap{min-height:calc(100vh - 70px);display:flex;align-items:center;justify-content:center;padding:40px 20px}
.welcome-card{background:#fff;border-radius:20px;padding:48px;max-width:740px;width:100%;box-shadow:0 8px 48px rgba(0,0,0,.09)}
.welcome-hero{text-align:center;margin-bottom:36px}
.welcome-icon{width:76px;height:76px;background:linear-gradient(135deg,#dbeafe,#e0f2fe);border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:34px;margin:0 auto 18px}
.welcome-hero h2{font-size:27px;font-weight:900;color:var(--navy);letter-spacing:-.5px;margin-bottom:10px}
.welcome-hero p{font-size:14px;color:var(--gray-500);line-height:1.65;max-width:500px;margin:0 auto}
.pillars-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:32px}
.pillar-chip{background:var(--gray-50);border:1px solid var(--gray-200);border-radius:10px;padding:12px 8px;text-align:center}
.pillar-chip .icon{font-size:20px;margin-bottom:5px}
.pillar-chip .label{font-size:10px;font-weight:700;color:var(--gray-600);line-height:1.3;text-transform:uppercase;letter-spacing:.3px}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:22px}
.form-group{display:flex;flex-direction:column;gap:5px}
.form-group.full{grid-column:span 2}
.form-group label{font-size:12px;font-weight:700;color:var(--gray-700);text-transform:uppercase;letter-spacing:.4px}
.form-group input,.form-group select,.form-group textarea{border:1.5px solid var(--gray-200);border-radius:8px;padding:10px 13px;font-size:14px;color:var(--gray-800);outline:none;transition:border-color .2s;font-family:inherit;background:#fff}
.form-group input:focus,.form-group select:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,.1)}
.btn{display:inline-flex;align-items:center;gap:8px;padding:11px 22px;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;border:none;transition:all .18s;text-decoration:none;font-family:inherit}
.btn-primary{background:linear-gradient(135deg,var(--blue),#1d4ed8);color:#fff}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 6px 22px rgba(37,99,235,.38)}
.btn-secondary{background:#fff;color:var(--gray-700);border:1.5px solid var(--gray-300)}
.btn-secondary:hover{background:var(--gray-50);border-color:var(--gray-400)}
.btn-outline-blue{background:transparent;color:var(--blue);border:1.5px solid var(--blue)}
.btn-outline-blue:hover{background:#eff6ff}
.btn-lg{padding:14px 32px;font-size:15px;border-radius:12px}
.btn-full{width:100%;justify-content:center}
.btn-green{background:linear-gradient(135deg,var(--green),#059669);color:#fff}
.btn-green:hover{box-shadow:0 6px 20px rgba(16,185,129,.38)}
.assessment-layout{display:flex;min-height:calc(100vh - 70px)}
.assessment-sidebar{width:270px;background:#fff;border-right:1px solid var(--gray-200);padding:20px 14px;position:sticky;top:70px;height:calc(100vh - 70px);overflow-y:auto;flex-shrink:0}
.score-widget{background:linear-gradient(135deg,var(--navy),var(--navy-mid));border-radius:12px;padding:16px;margin-bottom:16px;color:#fff}
.score-widget-label{font-size:10px;font-weight:700;opacity:.65;text-transform:uppercase;letter-spacing:.6px;margin-bottom:4px}
.score-widget-value{font-size:38px;font-weight:900;letter-spacing:-2px;line-height:1}
.score-widget-level{font-size:11px;opacity:.75;margin-top:4px}
.score-widget-bar{height:4px;background:rgba(255,255,255,.2);border-radius:2px;margin-top:10px}
.score-widget-bar-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--sky),var(--green));transition:width .5s ease}
.sidebar-progress-label{font-size:10px;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}
.sidebar-progress-bar{height:5px;background:var(--gray-200);border-radius:3px;margin-bottom:5px}
.sidebar-progress-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--sky));border-radius:3px;transition:width .4s}
.sidebar-progress-text{font-size:11px;color:var(--gray-400);margin-bottom:16px}
.sidebar-pillar-header{font-size:10px;font-weight:800;color:var(--gray-400);text-transform:uppercase;letter-spacing:.6px;padding:6px 8px;margin-top:8px}
.sidebar-domain{padding:7px 8px 7px 20px;font-size:12px;color:var(--gray-500);border-radius:7px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;transition:all .14s;gap:6px}
.sidebar-domain:hover{background:var(--gray-50);color:var(--gray-700)}
.sidebar-domain.active{background:#dbeafe;color:var(--blue);font-weight:700}
.sidebar-domain.completed{color:var(--green)}
.domain-check{width:16px;height:16px;border-radius:50%;border:1.5px solid currentColor;display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0}
.sidebar-domain.completed .domain-check{background:var(--green);border-color:var(--green);color:#fff}
.assessment-main{flex:1;padding:28px 32px;overflow-y:auto}
.domain-header{margin-bottom:24px}
.domain-breadcrumb{font-size:12px;color:var(--gray-400);margin-bottom:6px}
.domain-breadcrumb strong{color:var(--blue)}
.domain-title{font-size:22px;font-weight:900;color:var(--navy);letter-spacing:-.4px;margin-bottom:4px}
.domain-desc{font-size:13px;color:var(--gray-500);line-height:1.5}
.question-card{background:#fff;border:1.5px solid var(--gray-200);border-radius:14px;padding:22px;margin-bottom:14px;transition:border-color .18s}
.question-card:hover{border-color:var(--gray-300)}
.question-card.answered{border-color:#bfdbfe}
.question-num{font-size:10px;font-weight:800;color:var(--blue);text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px}
.question-text{font-size:14px;font-weight:700;color:var(--gray-800);margin-bottom:14px;line-height:1.55}
.options-list{display:flex;flex-direction:column;gap:7px}
.option-item{display:flex;align-items:flex-start;gap:11px;padding:11px 14px;border:1.5px solid var(--gray-200);border-radius:10px;cursor:pointer;transition:all .14s}
.option-item:hover{border-color:#93c5fd;background:#f0f7ff}
.option-item.selected{border-color:var(--blue);background:#eff6ff}
.option-radio{width:17px;height:17px;border:2px solid var(--gray-300);border-radius:50%;flex-shrink:0;margin-top:1px;transition:all .14s;position:relative}
.option-item.selected .option-radio{border-color:var(--blue);background:var(--blue)}
.option-item.selected .option-radio::after{content:'';width:5px;height:5px;background:#fff;border-radius:50%;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)}
.option-text{font-size:13px;color:var(--gray-700);line-height:1.45;flex:1}
.option-score-badge{margin-left:auto;font-size:10px;font-weight:800;padding:2px 8px;border-radius:20px;flex-shrink:0;align-self:flex-start;margin-top:1px}
.sb-3{background:#dcfce7;color:#15803d}.sb-2{background:#fef9c3;color:#854d0e}.sb-1{background:#ffedd5;color:#9a3412}.sb-0{background:#fee2e2;color:#991b1b}
.assessment-nav{display:flex;align-items:center;justify-content:space-between;margin-top:28px;padding-top:22px;border-top:1px solid var(--gray-200)}
.nav-info{font-size:12px;color:var(--gray-400)}
.dashboard{padding:28px 32px;max-width:1400px;margin:0 auto}
.dash-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:14px}
.dash-header h2{font-size:26px;font-weight:900;color:var(--navy);letter-spacing:-.5px}
.dash-header p{font-size:13px;color:var(--gray-500);margin-top:5px}
.dash-actions{display:flex;gap:9px;flex-wrap:wrap}
.dsi-hero{background:linear-gradient(135deg,var(--navy) 0%,#1e3a5f 50%,#1e40af 100%);border-radius:18px;padding:28px 32px;margin-bottom:24px;display:flex;align-items:center;gap:32px;color:#fff;position:relative;overflow:hidden}
.dsi-hero::before{content:'';position:absolute;top:-40px;right:-40px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.04)}
.dsi-score-ring{position:relative;width:120px;height:120px;flex-shrink:0}
.dsi-score-ring canvas{position:absolute;top:0;left:0}
.dsi-score-text{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center}
.dsi-score-num{font-size:30px;font-weight:900;letter-spacing:-2px;line-height:1}
.dsi-score-pct{font-size:12px;opacity:.7}
.dsi-meta h3{font-size:20px;font-weight:900;letter-spacing:-.3px;margin-bottom:6px}
.dsi-meta p{font-size:13px;opacity:.75;line-height:1.55;max-width:400px;margin-bottom:14px}
.maturity-badge{display:inline-block;padding:6px 18px;border-radius:30px;font-size:13px;font-weight:800;letter-spacing:.3px}
.mb-optimisant{background:rgba(16,185,129,.25);color:#6ee7b7}
.mb-géré{background:rgba(37,99,235,.25);color:#93c5fd}
.mb-défini{background:rgba(245,158,11,.25);color:#fcd34d}
.mb-développement{background:rgba(239,68,68,.25);color:#fca5a5}
.mb-initial{background:rgba(239,68,68,.35);color:#fca5a5}
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px}
.kpi-card{background:#fff;border:1.5px solid var(--gray-200);border-radius:14px;padding:18px;position:relative;overflow:hidden}
.kpi-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.kpi-green::before{background:var(--green)}.kpi-blue::before{background:var(--blue)}.kpi-amber::before{background:var(--amber)}.kpi-red::before{background:var(--red)}.kpi-sky::before{background:var(--sky)}
.kpi-label{font-size:11px;font-weight:700;color:var(--gray-500);text-transform:uppercase;letter-spacing:.4px;margin-bottom:8px}
.kpi-value{font-size:30px;font-weight:900;letter-spacing:-1.5px;margin-bottom:4px;line-height:1}
.kv-green{color:var(--green)}.kv-blue{color:var(--blue)}.kv-amber{color:var(--amber)}.kv-red{color:var(--red)}.kv-sky{color:var(--sky)}
.kpi-sub{font-size:11px;color:var(--gray-400);margin-bottom:10px}
.kpi-mini-bar{height:3px;background:var(--gray-200);border-radius:2px}
.kpi-mini-bar-fill{height:100%;border-radius:2px;transition:width .6s}
.fill-green{background:var(--green)}.fill-blue{background:var(--blue)}.fill-amber{background:var(--amber)}.fill-red{background:var(--red)}.fill-sky{background:var(--sky)}
.charts-row{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:24px}
.chart-card{background:#fff;border:1.5px solid var(--gray-200);border-radius:14px;padding:22px}
.chart-card.wide{grid-column:span 2}
.chart-title{font-size:14px;font-weight:800;color:var(--gray-800);margin-bottom:3px}
.chart-sub{font-size:11px;color:var(--gray-400);margin-bottom:18px}
.chart-wrap{position:relative;height:260px}
.domain-scores-section{background:#fff;border:1.5px solid var(--gray-200);border-radius:14px;margin-bottom:24px;overflow:hidden}
.section-heading{padding:18px 22px;border-bottom:1px solid var(--gray-100);display:flex;align-items:center;justify-content:space-between}
.section-heading h3{font-size:14px;font-weight:800;color:var(--gray-800)}
.section-heading p{font-size:11px;color:var(--gray-400)}
table.scores-table{width:100%;border-collapse:collapse}
.scores-table th{text-align:left;font-size:10px;font-weight:800;color:var(--gray-400);text-transform:uppercase;letter-spacing:.5px;padding:10px 20px;background:var(--gray-50);border-bottom:1px solid var(--gray-200)}
.scores-table td{padding:13px 20px;border-bottom:1px solid var(--gray-100);font-size:13px;vertical-align:middle}
.scores-table tr:last-child td{border-bottom:none}
.scores-table tr:hover td{background:var(--gray-50)}
.score-pill{display:inline-flex;align-items:center;padding:3px 11px;border-radius:20px;font-size:12px;font-weight:800}
.sp-excellent{background:#dcfce7;color:#15803d}.sp-good{background:#d1fae5;color:#065f46}.sp-fair{background:#fef9c3;color:#713f12}.sp-poor{background:#ffedd5;color:#9a3412}.sp-critical{background:#fee2e2;color:#991b1b}
.inline-bar{height:7px;background:var(--gray-200);border-radius:4px;width:100px;overflow:hidden;display:inline-block;vertical-align:middle}
.inline-bar-fill{height:100%;border-radius:4px}
.pillar-tag{display:inline-block;padding:2px 9px;border-radius:20px;font-size:10px;font-weight:700}
.pt-1{background:#ede9fe;color:#6d28d9}.pt-2{background:#dbeafe;color:#1d4ed8}.pt-3{background:#fce7f3;color:#9d174d}.pt-4{background:#d1fae5;color:#065f46}.pt-5{background:#fef9c3;color:#713f12}
.recs-section{margin-bottom:24px}
.recs-section h3{font-size:15px;font-weight:800;color:var(--gray-800);margin-bottom:12px}
.recs-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.rec-card{background:#fff;border:1.5px solid var(--gray-200);border-radius:12px;padding:16px;display:flex;gap:12px;align-items:flex-start}
.rec-pri{width:26px;height:26px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:900;flex-shrink:0}
.rp-high{background:#fee2e2;color:#991b1b}.rp-medium{background:#fef9c3;color:#713f12}.rp-low{background:#dcfce7;color:#15803d}
.rec-card h4{font-size:13px;font-weight:800;color:var(--gray-800);margin-bottom:4px}
.rec-card p{font-size:12px;color:var(--gray-500);line-height:1.5}
.rec-card .rec-domain{font-size:10px;font-weight:700;color:var(--blue);margin-bottom:4px}
@media print{.header{background:var(--navy)!important;position:relative!important}.no-print{display:none!important}body{background:#fff}}
::-webkit-scrollbar{width:5px;height:5px}::-webkit-scrollbar-thumb{background:var(--gray-300);border-radius:3px}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.fade-in{animation:fadeIn .28s ease}
@media(max-width:900px){
  .assessment-sidebar{display:none}.assessment-main{padding:16px}
  .kpi-grid{grid-template-columns:repeat(2,1fr)}.charts-row{grid-template-columns:1fr}
  .chart-card.wide{grid-column:span 1}.recs-grid{grid-template-columns:1fr}
  .pillars-grid{grid-template-columns:repeat(3,1fr)}.form-grid{grid-template-columns:1fr}
  .form-group.full{grid-column:span 1}.dsi-hero{flex-direction:column;gap:20px}
}
</style>
</head>
<body>

<header class="header">
  <div class="header-brand">
    <div class="header-logo">SN</div>
    <div class="header-title">
      <h1>OESD</h1>
      <p>Outil d'Évaluation de la Souveraineté Numérique &amp; des Données</p>
    </div>
  </div>
  <div class="header-right">
    <span id="header-org" class="header-badge" style="display:none"></span>
    <span class="header-badge">v2.0 — FR</span>
  </div>
</header>

<!-- VUE ACCUEIL -->
<div id="view-welcome" class="view active">
<div class="welcome-wrap">
<div class="welcome-card fade-in">
  <div class="welcome-hero">
    <div class="welcome-icon">🛡️</div>
    <h2>Évaluation de la Souveraineté Numérique</h2>
    <p>Établissez le niveau de référence de votre organisation dans tous les domaines de souveraineté — de la résidence des données à la gouvernance de l'IA, du chiffrement aux pistes d'audit des fournisseurs et à la supervision exécutive.</p>
  </div>
  <div class="pillars-grid">
    <div class="pillar-chip"><div class="icon">⚖️</div><div class="label">Juridique &amp; Réglementaire</div></div>
    <div class="pillar-chip"><div class="icon">🗄️</div><div class="label">Données &amp; Infrastructure</div></div>
    <div class="pillar-chip"><div class="icon">🏗️</div><div class="label">Infras. Critiques</div></div>
    <div class="pillar-chip"><div class="icon">🌐</div><div class="label">Flux Transfrontaliers</div></div>
    <div class="pillar-chip"><div class="icon">🏛️</div><div class="label">Capacité Institutionnelle</div></div>
  </div>
  <div class="form-grid">
    <div class="form-group">
      <label>Nom de l'organisation *</label>
      <input type="text" id="org-name" placeholder="Ministère du Numérique" />
    </div>
    <div class="form-group">
      <label>Type d'organisation *</label>
      <select id="org-type">
        <option value="">Sélectionner…</option>
        <option>Administration centrale</option>
        <option>Autorité de régulation</option>
        <option>Défense / Renseignement</option>
        <option>Opérateur d'infrastructure critique</option>
        <option>Entreprise publique</option>
        <option>Services financiers</option>
        <option>Santé</option>
        <option>Énergie &amp; Utilities</option>
        <option>Télécommunications</option>
        <option>Autre secteur public</option>
      </select>
    </div>
    <div class="form-group">
      <label>Pays / Juridiction *</label>
      <input type="text" id="org-country" placeholder="ex. France" />
    </div>
    <div class="form-group">
      <label>Responsable de l'évaluation</label>
      <input type="text" id="assessor-name" placeholder="Nom &amp; Titre" />
    </div>
    <div class="form-group full">
      <label>Périmètre / Notes</label>
      <input type="text" id="assessment-scope" placeholder="ex. Ensemble de l'infrastructure numérique de l'État, hors systèmes classifiés" />
    </div>
  </div>
  <button class="btn btn-primary btn-lg btn-full" onclick="startAssessment()">
    <span>Commencer l'évaluation</span>
    <span>→</span>
  </button>
  <p style="text-align:center;font-size:12px;color:var(--gray-400);margin-top:14px">~25–35 minutes · 84 questions · 14 domaines · Rapport KPI complet généré automatiquement</p>
</div>
</div>
</div>

<!-- VUE ÉVALUATION -->
<div id="view-assessment" class="view">
<div class="assessment-layout">
  <aside class="assessment-sidebar" id="sidebar"></aside>
  <main class="assessment-main" id="assessment-main"></main>
</div>
</div>

<!-- VUE TABLEAU DE BORD -->
<div id="view-dashboard" class="view">
<div class="dashboard" id="dashboard-content"></div>
</div>

<script>
// ============================================================
// DONNÉES DE L'ÉVALUATION
// ============================================================
const PILLARS = [
  { id:'P1', label:'Alignement Juridique & Réglementaire', color:'#7c3aed', tag:'pt-1' },
  { id:'P2', label:'Localisation des Données & Infrastructure', color:'#2563eb', tag:'pt-2' },
  { id:'P3', label:'Protection des Infrastructures Critiques', color:'#db2777', tag:'pt-3' },
  { id:'P4', label:'Gouvernance des Flux Transfrontaliers', color:'#059669', tag:'pt-4' },
  { id:'P5', label:'Capacité Institutionnelle & Supervision', color:'#d97706', tag:'pt-5' }
];

const DOMAINS = [
  { id:'legal',        pillar:'P1', label:'Cadre Juridique & Réglementaire',            desc:"Législation nationale sur la protection des données, droit de l'IA, statut de l'autorité de contrôle.", icon:'⚖️' },
  { id:'dataprotect',  pillar:'P1', label:'Conformité à la Protection des Données',     desc:'Désignation DPO, AIPD, notification de violation, gestion du consentement.', icon:'🔐' },
