function renderKPICards(){
  const kpis=generateKPIs();
  function cardHtml(kpi){
    return `<div class="kpi-card kpi-${kpi.color}">
      <div class="kpi-label">${kpi.label}</div>
      <div class="kpi-value kv-${kpi.color}">${kpi.value}</div>
