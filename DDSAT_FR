      <div class="kpi-mini-bar"><div class="kpi-mini-bar-fill fill-${kpi.color}" style="width:${kpi.pct}%"></div></div>
    </div>`;
  }
  const g1=document.getElementById('kpi-grid');
  const g2=document.getElementById('kpi-grid-2');
  if(g1) g1.innerHTML=kpis.slice(0,8).map(cardHtml).join('');
  if(g2) g2.innerHTML=kpis.slice(8).map(cardHtml).join('');
}

function generateKPIs(){
  const s=n=>domainScore(n);
  const ps=pid=>pillarScore(pid);
  const overall=overallScore();
  const c=sc=>{if(sc>=80)return'green';if(sc>=60)return'blue';if(sc>=40)return'amber';return'red';};
  const kpi=(label,raw,unit,sub)=>({label,value:`${raw}${unit||'%'}`,pct:raw,color:c(raw),sub});
  return [
    kpi('Indice de Souveraineté Numérique (ISN)',overall,'','Score global de posture de souveraineté'),
    kpi('Alignement Juridique & Réglementaire',ps('P1'),'','Pilier 1 — maturité du cadre juridique'),
    kpi('Conformité Résidence des Données',Math.round((s('residency')+s('cloud'))/2),'','Localisation des données et souveraineté cloud'),
    kpi("Score de Contrôle des Infrastructures",Math.round((s('infra')+s('cloud'))/2),'','Propriété et contrôle des infrastructures nationales'),
    kpi('Souveraineté du Chiffrement',s('encrypt'),'','Gestion des clés et normes cryptographiques'),
    kpi("Indice de Gouvernance de l'IA",s('aiGov'),'','Inventaire IA, supervision et provenance des données'),
    kpi('Risque de Dépendance Fournisseur',100-Math.round((s('vendor')+s('vendoraudit'))/2),'%','Inversé : plus bas = plus souverain (risque plus élevé)'),
    kpi('Gouvernance des Flux Transfrontaliers',s('crossborder'),'','Contrôles des flux de données internationaux'),
    kpi('Résilience Infrastructures Critiques',s('critinfra'),'','Maturité du programme PIC / protection OIV'),
    kpi('Maturité IAM',s('iam'),'','Robustesse de la gestion des identités et des accès'),
    kpi('Résilience Opérationnelle',s('ops'),'','Indépendance opérationnelle en crise'),
    kpi("Indice de Supervision Exécutive",s('institutional'),'','Responsabilité et stratégie au niveau de la direction'),
  ];
}

function generateRecommendations(){
  const actions={
    legal:"Adopter ou renforcer une loi nationale de protection des données avec une APD indépendante dotée de pouvoirs d'application.",
    dataprotect:"Nommer un DPD qualifié, mettre en place des AIPD systématiques et tester les procédures de notification de violation.",
    residency:"Réaliser un inventaire des données, imposer des clauses de résidence dans tous les contrats fournisseurs et vérifier la conformité.",
    infra:"Accroître la propriété nationale de l'infrastructure informatique critique ; établir des procédures opérationnelles indépendantes des fournisseurs.",
    cloud:"Adopter une stratégie cloud souverain, réviser tous les contrats cloud pour les dispositions de juridiction et de sortie.",
    encrypt:"Déployer des HSM sous contrôle national, appliquer les normes cryptographiques et établir une gouvernance du cycle de vie des clés.",
    critinfra:"Formaliser un registre OIV, établir un CSIRT 24h/24 avec mandat OIV et organiser des exercices annuels.",
    vendor:"Mettre en place une liste de fournisseurs interdits, rendre obligatoires les clauses de souveraineté dans tous les contrats et vérifier la chaîne d'approvisionnement.",
    crossborder:"Introduire une politique de transfert transfrontalier, réaliser des analyses d'impact des transferts et tenir un registre des flux.",
    vendoraudit:"Déployer une journalisation immuable des accès fournisseurs, imposer les accès JIT à privilèges et rendre obligatoire la supervision des sessions de support.",
    iam:"Déployer un IAM et PAM d'entreprise, imposer le MFA universellement, mettre en œuvre une architecture zéro confiance.",
    aiGov:"Créer un inventaire complet des systèmes d'IA, mettre en œuvre un cadre de gouvernance IA et contrôler la provenance des données d'entraînement.",
    ops:"Développer des procédures opérationnelles indépendantes des fournisseurs, tester les scénarios PCA souveraineté et investir dans les compétences cyber nationales.",
    institutional:"Nommer un responsable souveraineté au niveau du conseil, établir un budget fléché et définir des KPI de souveraineté mesurables."
  };
  return DOMAINS.map(d=>{
    const s=domainScore(d.id);
    return {domain:d.label,title:`Améliorer : ${d.label}`,desc:actions[d.id],priority:s<40?'high':s<65?'medium':'low',score:s};
  }).sort((a,b)=>a.score-b.score);
}

function destroyChart(id){if(state.charts[id]){state.charts[id].destroy();delete state.charts[id];}}

function renderRingChart(score){
  destroyChart('dsi');
  const ctx=document.getElementById('dsiRing').getContext('2d');
  state.charts['dsi']=new Chart(ctx,{type:'doughnut',data:{datasets:[{data:[score,100-score],backgroundColor:[scoreColorHex(score),'rgba(255,255,255,0.1)'],borderWidth:0}]},options:{cutout:'72%',plugins:{legend:{display:false},tooltip:{enabled:false}},animation:{duration:1000}}});
}

function renderRadarChart(scores){
  destroyChart('radar');
  const ctx=document.getElementById('radarChart').getContext('2d');
  state.charts['radar']=new Chart(ctx,{type:'radar',data:{labels:PILLARS.map(p=>p.label.split(' ').slice(0,3).join(' ')),datasets:[{label:'Score',data:scores,backgroundColor:'rgba(37,99,235,0.15)',borderColor:'#2563eb',borderWidth:2,pointBackgroundColor:'#2563eb',pointRadius:4}]},options:{scales:{r:{min:0,max:100,ticks:{stepSize:20,font:{size:10}},grid:{color:'rgba(0,0,0,0.07)'},pointLabels:{font:{size:11,weight:'700'},color:'#334155'}}},plugins:{legend:{display:false}},animation:{duration:800}}});
}

function renderPillarBar(scores){
  destroyChart('pillarBar');
  const ctx=document.getElementById('pillarBar').getContext('2d');
  state.charts['pillarBar']=new Chart(ctx,{type:'bar',data:{labels:PILLARS.map(p=>`P${PILLARS.indexOf(p)+1}`),datasets:[{label:'Score Pilier',data:scores,backgroundColor:scores.map(s=>scoreColorHex(s)+'cc'),borderColor:scores.map(scoreColorHex),borderWidth:2,borderRadius:8}]},options:{scales:{y:{min:0,max:100,ticks:{stepSize:20},grid:{color:'rgba(0,0,0,0.05)'}},x:{grid:{display:false}}},plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`Score : ${c.raw}%`}}},animation:{duration:800}}});
}

function renderDomainBar(){
  destroyChart('domainBar');
  const ctx=document.getElementById('domainBar').getContext('2d');
  const scores=DOMAINS.map(d=>domainScore(d.id));
  const labels=DOMAINS.map(d=>d.label);
  state.charts['domainBar']=new Chart(ctx,{type:'bar',data:{labels,datasets:[{label:'Score Domaine',data:scores,backgroundColor:scores.map(s=>scoreColorHex(s)+'cc'),borderColor:scores.map(scoreColorHex),borderWidth:1.5,borderRadius:6}]},options:{indexAxis:'y',scales:{x:{min:0,max:100,ticks:{stepSize:20},grid:{color:'rgba(0,0,0,0.05)'}},y:{grid:{display:false},ticks:{font:{size:11}}}},plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`${c.raw}%`}}},animation:{duration:600}}});
}
</script>
</body>
</html>
