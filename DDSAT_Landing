
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DDSAT — Digital & Data Sovereignty Assessment Tool | Talisman Cybersecurity</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --dark:    #080e1a;
    --navy:    #0d1b2e;
    --navy2:   #0f2744;
    --blue:    #0e4d8a;
    --cyan:    #00b4d8;
    --cyan2:   #00e5ff;
    --gold:    #f59e0b;
    --white:   #ffffff;
    --light:   #e2eaf4;
    --muted:   #8fa3bc;
    --card-bg: #0d1e35;
    --border:  rgba(0,180,216,0.15);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--dark);
    color: var(--light);
    line-height: 1.7;
    font-size: 16px;
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    background: linear-gradient(135deg, #060d1a 0%, #0a1928 40%, #0d2240 100%);
    padding: 100px 24px 80px;
    text-align: center;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% -10%, rgba(0,180,216,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 80% 80%, rgba(14,77,138,0.18) 0%, transparent 60%);
    pointer-events: none;
  }

  /* Grid lines background */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,180,216,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,180,216,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }

  .hero-inner { position: relative; z-index: 1; max-width: 860px; margin: 0 auto; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,180,216,0.1);
    border: 1px solid rgba(0,180,216,0.3);
    color: var(--cyan);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 28px;
  }

  .hero-badge::before { content: '◆'; font-size: 8px; }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 10px;
  }

  .hero-title span { color: var(--cyan); }

  .hero-acronym {
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 800;
    letter-spacing: 0.12em;
    background: linear-gradient(135deg, var(--cyan2) 0%, var(--cyan) 50%, #0077b6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: block;
    margin: 8px 0 20px;
    line-height: 1;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 640px;
    margin: 0 auto 40px;
  }

  .hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-bottom: 48px;
  }

  .pill {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--light);
    font-size: 13px;
    padding: 6px 14px;
    border-radius: 100px;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, var(--cyan) 0%, #0077b6 100%);
    color: var(--dark);
    font-weight: 700;
    font-size: 15px;
    padding: 14px 28px;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
    box-shadow: 0 4px 20px rgba(0,180,216,0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0,180,216,0.45);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 2px solid rgba(0,180,216,0.5);
    color: var(--cyan);
    font-weight: 600;
    font-size: 15px;
    padding: 13px 28px;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    background: rgba(0,180,216,0.08);
    border-color: var(--cyan);
    transform: translateY(-2px);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 2px solid rgba(255,255,255,0.2);
    color: var(--light);
    font-weight: 600;
    font-size: 15px;
    padding: 13px 28px;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-outline:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.4);
    transform: translateY(-2px);
  }

  /* ── STATS BAR ── */
  .stats-bar {
    background: var(--navy2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 32px 24px;
  }

  .stats-inner {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 24px;
    text-align: center;
  }

  .stat-item { display: flex; flex-direction: column; align-items: center; gap: 4px; }

  .stat-num {
    font-size: 2rem;
    font-weight: 800;
    color: var(--cyan);
    line-height: 1;
  }

  .stat-label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }

  /* ── SECTIONS ── */
  section { padding: 80px 24px; }

  .section-inner { max-width: 1100px; margin: 0 auto; }

  .section-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 12px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 16px;
    line-height: 1.25;
  }

  .section-lead { font-size: 1.05rem; color: var(--muted); max-width: 680px; }

  .section-header { margin-bottom: 48px; }

  /* ── WHAT IS DDSAT ── */
  .what-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  @media(max-width:700px){ .what-grid { grid-template-columns: 1fr; } }

  .what-text p { color: var(--muted); margin-bottom: 16px; font-size: 1rem; }
  .what-text p strong { color: var(--light); }

  .what-features { display: flex; flex-direction: column; gap: 16px; }

  .feature-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px 20px;
    transition: border-color 0.2s;
  }

  .feature-item:hover { border-color: rgba(0,180,216,0.4); }

  .feature-icon {
    font-size: 1.6rem;
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,180,216,0.1);
    border-radius: 8px;
  }

  .feature-text h4 { font-size: 14px; font-weight: 600; color: var(--white); margin-bottom: 4px; }
  .feature-text p { font-size: 13px; color: var(--muted); line-height: 1.5; }

  /* ── PILLARS ── */
  .pillars-section { background: var(--navy); }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 16px;
  }

  .pillar-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-top: 3px solid var(--pillar-color, var(--cyan));
    border-radius: 10px;
    padding: 24px 20px;
    transition: all 0.2s;
  }

  .pillar-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.4); }

  .pillar-icon { font-size: 1.8rem; margin-bottom: 12px; }
  .pillar-num { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; color: var(--muted); text-transform: uppercase; margin-bottom: 6px; }
  .pillar-name { font-size: 14px; font-weight: 700; color: var(--white); margin-bottom: 8px; line-height: 1.3; }
  .pillar-weight {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    background: rgba(0,180,216,0.12);
    color: var(--cyan);
    border-radius: 100px;
    padding: 2px 10px;
    margin-bottom: 10px;
  }
  .pillar-desc { font-size: 12px; color: var(--muted); line-height: 1.5; }

  /* ── HOW IT WORKS ── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0;
    position: relative;
  }

  .steps-grid::before {
    content: '';
    position: absolute;
    top: 36px;
    left: 10%;
    right: 10%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    opacity: 0.3;
  }

  .step-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 28px 20px;
    text-align: center;
    margin: 8px;
    transition: all 0.2s;
  }

  .step-card:hover { border-color: rgba(0,180,216,0.4); }

  .step-num {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--cyan) 0%, var(--blue) 100%);
    color: var(--dark);
    font-size: 18px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    box-shadow: 0 4px 16px rgba(0,180,216,0.3);
  }

  .step-title { font-size: 15px; font-weight: 700; color: var(--white); margin-bottom: 8px; }
  .step-desc { font-size: 13px; color: var(--muted); line-height: 1.5; }
  .step-time { font-size: 11px; color: var(--cyan); font-weight: 600; margin-top: 10px; text-transform: uppercase; letter-spacing: 0.08em; }

  /* ── TOOLS GRID ── */
  .tools-section { background: linear-gradient(180deg, var(--dark) 0%, var(--navy) 100%); }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
  }

  .tool-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
  }

  .tool-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--tool-color, var(--cyan));
  }

  .tool-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.5);
    border-color: rgba(0,180,216,0.3);
  }

  .tool-icon { font-size: 2.2rem; }
  .tool-lang {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
    background: rgba(245,158,11,0.15);
    color: var(--gold);
    border: 1px solid rgba(245,158,11,0.2);
    width: fit-content;
  }

  .tool-card h3 { font-size: 18px; font-weight: 700; color: var(--white); line-height: 1.3; }
  .tool-card p { font-size: 14px; color: var(--muted); line-height: 1.6; flex: 1; }

  .tool-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tool-tag {
    font-size: 11px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    color: var(--muted);
    padding: 3px 10px;
    border-radius: 100px;
  }

  /* ── KPI / DSI SECTION ── */
  .dsi-section { background: var(--navy); }

  .dsi-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 48px;
    align-items: center;
  }

  @media(max-width:700px){ .dsi-grid { grid-template-columns: 1fr; } }

  .dsi-score-display {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 40px;
    text-align: center;
  }

  .dsi-ring {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: conic-gradient(var(--cyan) 0% 43%, rgba(0,180,216,0.1) 43% 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
    position: relative;
  }

  .dsi-ring::before {
    content: '';
    width: 120px;
    height: 120px;
    background: var(--card-bg);
    border-radius: 50%;
    position: absolute;
  }

  .dsi-ring-label {
    position: relative;
    z-index: 1;
    font-size: 2rem;
    font-weight: 800;
    color: var(--white);
  }

  .dsi-ring-sub { font-size: 12px; color: var(--muted); display: block; font-weight: 400; }

  .dsi-score-display h4 { font-size: 15px; font-weight: 700; color: var(--white); margin-bottom: 6px; }
  .dsi-score-display p { font-size: 13px; color: var(--muted); }

  .dsi-maturity {
    display: inline-block;
    background: rgba(245,158,11,0.15);
    border: 1px solid rgba(245,158,11,0.3);
    color: var(--gold);
    font-size: 12px;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 100px;
    margin: 10px 0 20px;
  }

  .kpi-list { display: flex; flex-direction: column; gap: 12px; }

  .kpi-row {
    display: flex;
    align-items: center;
    gap: 14px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 16px;
  }

  .kpi-name { flex: 1; font-size: 13px; color: var(--light); font-weight: 500; }
  .kpi-bar-wrap { width: 100px; height: 6px; background: rgba(255,255,255,0.08); border-radius: 3px; }
  .kpi-bar { height: 6px; border-radius: 3px; background: var(--bar-color, var(--cyan)); }
  .kpi-val { font-size: 13px; font-weight: 700; color: var(--white); min-width: 36px; text-align: right; }

  /* ── WHITE PAPER ── */
  .wp-section { background: linear-gradient(135deg, #05111f 0%, #071729 100%); }

  .wp-card {
    background: linear-gradient(135deg, var(--navy2) 0%, #0a1e35 100%);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 48px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 40px;
    align-items: center;
  }

  @media(max-width:700px){ .wp-card { grid-template-columns: 1fr; } }

  .wp-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(245,158,11,0.1);
    border: 1px solid rgba(245,158,11,0.3);
    color: var(--gold);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 16px;
    width: fit-content;
  }

  .wp-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    color: var(--white);
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .wp-card p { font-size: 14px; color: var(--muted); line-height: 1.7; margin-bottom: 24px; }

  .wp-meta { display: flex; flex-wrap: wrap; gap: 16px; }
  .wp-meta-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--muted); }
  .wp-meta-item span { color: var(--cyan); }

  .wp-cover {
    width: 180px;
    flex-shrink: 0;
    background: linear-gradient(160deg, var(--navy2) 0%, #091525 100%);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 28px 20px;
    text-align: center;
    box-shadow: 8px 8px 32px rgba(0,0,0,0.5);
  }

  .wp-shield {
    font-size: 3rem;
    margin-bottom: 12px;
    display: block;
  }

  .wp-cover-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cyan);
    line-height: 1.4;
    margin-bottom: 8px;
  }

  .wp-cover-sub { font-size: 9px; color: var(--muted); }

  /* ── AUDIENCE ── */
  .audience-section { background: var(--dark); }

  .audience-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
  }

  .audience-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px 20px;
    text-align: center;
    transition: all 0.2s;
  }

  .audience-card:hover { border-color: rgba(0,180,216,0.4); transform: translateY(-3px); }

  .audience-icon { font-size: 2rem; margin-bottom: 12px; display: block; }
  .audience-name { font-size: 14px; font-weight: 700; color: var(--white); margin-bottom: 6px; }
  .audience-desc { font-size: 12px; color: var(--muted); line-height: 1.5; }

  /* ── FINAL CTA ── */
  .cta-section {
    background: linear-gradient(135deg, #050e1c 0%, #081828 50%, #0a1e32 100%);
    border-top: 1px solid var(--border);
    padding: 80px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(0,180,216,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-inner { position: relative; z-index: 1; max-width: 700px; margin: 0 auto; }

  .cta-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    color: var(--white);
    margin-bottom: 16px;
    line-height: 1.25;
  }

  .cta-section p { font-size: 1rem; color: var(--muted); margin-bottom: 36px; }

  .cta-buttons { display: flex; flex-wrap: wrap; gap: 16px; justify-content: center; }

  /* ── FOOTER NOTE ── */
  .footer-note {
    background: var(--navy);
    border-top: 1px solid var(--border);
    padding: 24px;
    text-align: center;
    font-size: 12px;
    color: var(--muted);
  }

  .footer-note a { color: var(--cyan); text-decoration: none; }
  .footer-note a:hover { text-decoration: underline; }

  /* ── DIVIDER ── */
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
    margin: 0;
  }

  /* Responsive tweaks */
  @media(max-width:600px) {
    .hero { padding: 80px 16px 60px; }
    section { padding: 60px 16px; }
    .steps-grid::before { display: none; }
    .wp-card { padding: 28px; }
  }
</style>
</head>
